# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   set by the user.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files should be committed, but
#   recommends ignoring them if you are developing a library.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock should be committed, but
#   recommends ignoring them if you are developing a library.
# poetry.lock

# pdm
#   Similar Python requirement as poetry.
.pdm-python
.pdm-build/

